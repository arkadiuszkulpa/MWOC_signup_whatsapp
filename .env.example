# =============================================================
# MWOC Signup — Environment Variables
# Copy this to .env and fill in your values
# =============================================================

# --- AWS ---
AWS_REGION=eu-west-1
PARTICIPANTS_TABLE=mwoc-participants

# --- WhatsApp Group ---
WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/YOUR_GROUP_INVITE_LINK

# --- WhatsApp Notification Mode ---
# Options: sns (default, sends SMS), business (Meta Cloud API), twilio
WHATSAPP_MODE=sns

# --- Meta WhatsApp Business API (if WHATSAPP_MODE=business) ---
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# --- Twilio (if WHATSAPP_MODE=twilio) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Mailchimp ---
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_LIST_ID=your_list_id

# --- Frontend ---
VITE_API_URL=https://YOUR_API_ID.execute-api.eu-west-1.amazonaws.com/prod
